# dependencies / build
node_modules/
/dist/
*.tsbuildinfo

# never commit the SDK tarball or any vendored package
/vendor/
*.tgz

# local-only: ops notes, scratch, the future test harness — never published
/internal/

# operator's real config + runtime state — only ospex-mm.example.yaml is committed
# (anchored with / so these don't match src/state/, src/telemetry/, etc.)
# NOTE: only the literal ./state/ name is ignored. For live runs put state.dir at an
# ABSOLUTE path OUTSIDE this repo — maker-state.json holds signed EIP-712 bearer payloads;
# an in-repo state.dir under any other name (e.g. ./live-state/) is NOT ignored and would
# be committed. See docs/OPERATOR_SAFETY.md (Sensitive local state).
/ospex-mm.yaml
/state/
/telemetry/
/KILL

# secrets / env
.env
.env.local

# misc
*.log
.DS_Store
