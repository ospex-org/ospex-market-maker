{
  "name": "ospex-market-maker",
  "version": "0.0.0",
  "private": true,
  "description": "Reference market maker for Ospex — a zero-vig peer-to-peer sports prediction protocol on Polygon. Clone, configure, run.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "ospex-mm": "./dist/cli/index.js"
  },
  "files": [
    "dist",
    "ospex-mm.example.yaml",
    "docs"
  ],
  "scripts": {
    "build": "tsc",
    "postbuild": "node scripts/chmod-bin.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint src",
    "dev": "tsx src/cli/index.ts",
    "mm": "node dist/cli/index.js",
    "prepack": "yarn build"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "eslint": "^9.17.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0",
    "vitest": "^3.0.0"
  }
}
